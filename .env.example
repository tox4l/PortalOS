# =============================================================================
# PortalOS - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# .env is git-ignored and must NEVER be committed.
#
# Legend:
#   [REQUIRED]  - App will not start or function without this in production.
#   [OPTIONAL]  - Feature degrades gracefully when absent.
#   [DEV ONLY]  - Ignored or harmful in production.

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# [REQUIRED] PostgreSQL connection string for Prisma.
# For production, use your managed PostgreSQL provider URL.
DATABASE_URL="postgresql://user:password@host:5432/portalos?schema=public"

# ---------------------------------------------------------------------------
# Auth - NextAuth v5
# ---------------------------------------------------------------------------
# [REQUIRED] Generated via: openssl rand -hex 32
AUTH_SECRET="replace-with-a-long-random-secret"

# [REQUIRED] Canonical public URL of the deployment (no trailing slash).
# Local: http://localhost:3000
# Production: https://your-domain.com
AUTH_URL="http://localhost:3000"

# [OPTIONAL] Google OAuth provider (https://console.cloud.google.com).
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Email - Resend
# ---------------------------------------------------------------------------
# [REQUIRED for magic link + email notifications]
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_2HvchEUN_L6smWLsWmDP75iLDjXgyxPCQ"

# [OPTIONAL] Sender address for transactional emails.
# Must be a verified domain in Resend.
RESEND_FROM_EMAIL="PortalOS <hello@portalos.app>"

# ---------------------------------------------------------------------------
# Storage - Supabase
# ---------------------------------------------------------------------------
# [REQUIRED for file uploads / deliverables]
# Get these from your Supabase project settings (https://supabase.com).
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ANON_KEY=""
SUPABASE_STORAGE_URL=""

# [OPTIONAL] Exposed to the browser when using Supabase client-side.
# Falls back to SUPABASE_URL / SUPABASE_ANON_KEY if unset.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ---------------------------------------------------------------------------
# Realtime - Ably
# ---------------------------------------------------------------------------
# [OPTIONAL] For real-time comments and activity feeds.
# Get your API key at https://ably.com.
ABLY_API_KEY=""

# [OPTIONAL] Exposed to the browser for client-side Ably subscriptions.
NEXT_PUBLIC_ABLY_KEY=""

# ---------------------------------------------------------------------------
# AI - OpenAI
# ---------------------------------------------------------------------------
# [OPTIONAL] Powers AI brief generation and project summaries.
# Features degrade gracefully without it.
OPENAI_API_KEY=""

# ---------------------------------------------------------------------------
# Analytics - PostHog
# ---------------------------------------------------------------------------
# [OPTIONAL] Product analytics.
POSTHOG_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ---------------------------------------------------------------------------
# Demo / Dev mode
# ---------------------------------------------------------------------------
# [DEV ONLY] Bypasses auth and returns mock data for the full showroom UI.
# Must be "false" or absent in production.
DEV_BYPASS_AUTH="false"

# [DEV ONLY] Enables demo mode features (demo credentials, seed data).
DEMO_MODE="false"

# ---------------------------------------------------------------------------
# Marketing / Sales
# ---------------------------------------------------------------------------
# [OPTIONAL] Calendly URL for the "Book a demo" CTA.
CALENDLY_URL="https://calendly.com/velocity-ai/portalos"

# [OPTIONAL] Contact inbox shown on the marketing page.
VELOCITY_AI_INBOX="hello@velocityai.example"
