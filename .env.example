# =============================================================================
# PortalOS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit it.
#
# Legend:
#   [REQUIRED]  — App won't start without it
#   [OPTIONAL]  — Feature degrades gracefully when absent
#   [DEV ONLY]  — Ignored or harmful in production

# ---------------------------------------------------------------------------
# Database — PostgreSQL (via Supabase)
# ---------------------------------------------------------------------------
# [REQUIRED] Get this from your Supabase project dashboard:
#   Settings > Database > Connection string
#   Replace [YOUR-PASSWORD] with your actual database password.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres"

# ---------------------------------------------------------------------------
# Auth — NextAuth v5
# ---------------------------------------------------------------------------
# [REQUIRED] Generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-32-char-random-hex"

# [REQUIRED] Your app's public URL (no trailing slash).
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
AUTH_URL="http://localhost:3000"

# [OPTIONAL] Google OAuth — https://console.cloud.google.com
# Create OAuth 2.0 credentials, set redirect URI to:
#   {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# ---------------------------------------------------------------------------
# [REQUIRED] API key from https://resend.com/api-keys
# Used for magic-link sign-in and email notifications.
RESEND_API_KEY="re_xxxxxxxxxxxx"

# [REQUIRED] Verified sending domain in Resend.
# Format: "Your Name <hello@yourdomain.com>"
RESEND_FROM_EMAIL="PortalOS <hello@yourdomain.com>"

# ---------------------------------------------------------------------------
# Storage — Supabase (https://supabase.com)
# ---------------------------------------------------------------------------
# [REQUIRED] From your Supabase project: Settings > API
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxx"

# [OPTIONAL] Custom storage URL if using a CDN or custom domain.
SUPABASE_STORAGE_URL=""

# [OPTIONAL] Public keys for browser-side Supabase usage.
# Falls back to SUPABASE_URL / SUPABASE_ANON_KEY if not set.
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"

# ---------------------------------------------------------------------------
# Realtime — Ably (https://ably.com)
# ---------------------------------------------------------------------------
# [OPTIONAL] For real-time comments and activity feeds.
ABLY_API_KEY=""

# [OPTIONAL] Browser-side Ably key.
NEXT_PUBLIC_ABLY_KEY=""

# ---------------------------------------------------------------------------
# AI — DeepSeek (https://platform.deepseek.com)
# ---------------------------------------------------------------------------
# [OPTIONAL] Powers AI brief generation and project summaries.
# Get your key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Analytics — PostHog (https://posthog.com)
# ---------------------------------------------------------------------------
# [OPTIONAL] Product analytics.
POSTHOG_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ---------------------------------------------------------------------------
# Payments — Stripe (https://stripe.com)
# ---------------------------------------------------------------------------
# [OPTIONAL] Not yet wired up — safe to leave blank.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Dev mode
# ---------------------------------------------------------------------------
# [DEV ONLY] Bypasses auth — auto-logs in as a demo user.
# Must be "false" in production. Set to "true" ONLY for local development.
DEV_BYPASS_AUTH="false"

# [DEV ONLY] Enables demo data and seed features.
DEMO_MODE="false"

# ---------------------------------------------------------------------------
# Marketing
# ---------------------------------------------------------------------------
# [OPTIONAL] Calendly link for "Book a call" CTAs.
CALENDLY_URL="https://calendly.com/your-org/30min"

# [OPTIONAL] Contact email shown on the marketing page.
VELOCITY_AI_INBOX="hello@yourdomain.com"
